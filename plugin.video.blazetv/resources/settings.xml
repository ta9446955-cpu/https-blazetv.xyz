<?xml version="1.0" encoding="UTF-8"?>
<settings version="1">
    <section id="plugin.video.blazetv">
        <category id="server" label="Server Settings">
            <group id="1" label="M3U Playlist">
                <setting id="m3u_url" type="path" label="M3U Playlist URL or File">
                    <level>0</level>
                    <default></default>
                    <constraints>
                        <allowempty>true</allowempty>
                    </constraints>
                    <control type="button" format="path">
                        <data>
                            <heading>Select M3U Playlist File or Enter URL</heading>
                        </data>
                    </control>
                </setting>
            </group>
            <group id="2" label="Xtream Codes (optional - leave M3U URL blank to use this instead)">
                <setting id="server_url" type="string" label="Server URL">
                    <level>0</level>
                    <default>http://mains.services/get.php</default>
                    <control type="edit" format="string"/>
                </setting>
                <setting id="username" type="string" label="Username">
                    <level>0</level>
                    <default></default>
                    <control type="edit" format="string"/>
                </setting>
                <setting id="password" type="string" label="Password">
                    <level>0</level>
                    <default></default>
                    <control type="edit" format="string">
                        <hidden>true</hidden>
                    </control>
                </setting>
                <setting id="type" type="string" label="Stream Type (m3u_plus/m3u/pls)">
                    <level>0</level>
                    <default>m3u_plus</default>
                    <control type="edit" format="string"/>
                </setting>
                <setting id="output" type="string" label="Output Format (ts/m3u8)">
                    <level>0</level>
                    <default>ts</default>
                    <control type="edit" format="string"/>
                </setting>
            </group>
        </category>
        <category id="display" label="Display">
            <group id="1" label="Interface">
                <setting id="show_categories" type="boolean" label="Show Channel Categories">
                    <level>0</level>
                    <default>true</default>
                    <control type="toggle"/>
                </setting>
                <setting id="load_epg" type="boolean" label="Load EPG Data">
                    <level>0</level>
                    <default>true</default>
                    <control type="toggle"/>
                </setting>
                <setting id="cache_duration" type="integer" label="Cache Duration (minutes)">
                    <level>0</level>
                    <default>60</default>
                    <constraints>
                        <minimum>5</minimum>
                        <maximum>1440</maximum>
                    </constraints>
                    <control type="edit" format="integer"/>
                </setting>
            </group>
        </category>
        <category id="features" label="Features">
            <group id="1" label="Advanced">
                <setting id="enable_search" type="boolean" label="Enable Channel Search">
                    <level>0</level>
                    <default>true</default>
                    <control type="toggle"/>
                </setting>
                <setting id="enable_history" type="boolean" label="Enable Playback History">
                    <level>0</level>
                    <default>true</default>
                    <control type="toggle"/>
                </setting>
                <setting id="history_days" type="integer" label="Keep History (days)">
                    <level>0</level>
                    <default>30</default>
                    <constraints>
                        <minimum>1</minimum>
                        <maximum>365</maximum>
                    </constraints>
                    <control type="edit" format="integer"/>
                </setting>
                <setting id="enable_debug" type="boolean" label="Enable Debug Logging">
                    <level>0</level>
                    <default>false</default>
                    <control type="toggle"/>
                </setting>
            </group>
        </category>
    </section>
</settings>
